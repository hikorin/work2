# アプリケーションおよび外部連携の設定
# 用途に合わせて以下のIDとパスワード（またはAPIキー）を入力してください。

# 1. アプリログイン用 (想定)
APP_LOGIN_ID=your_id_here
APP_LOGIN_PW=your_password_here

# 2. Google Spreadsheet API連携用 (スプレッドシートからデータを読み書きする場合)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_here
GOOGLE_PRIVATE_KEY="your_private_key_here"

# 3. データベース等の設定 (追加で必要になれば)
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=secret
